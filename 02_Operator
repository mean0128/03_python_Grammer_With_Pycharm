	# format 함수 이용
	# print(value, format())
print("원주율=", format(3.14159, "8.3f") ) #원주율=    3.142
print("원주율=", format(3.14159, "7.3f") ) #원주율=   3.142
print("원주율=", format(3.14159, "6.3f") ) #원주율=  3.142
print("원주율=", format(3.14159, "5.3f") ) #원주율= 3.142

print("금액 =", format(10000, "10d")) #금액 =      10000
print("금액 =", format(10000, "9d"))  #금액 =     10000
print("금액 =", format(10000, "8d"))  #금액 =    10000
print("금액 =", format(10000, "7d"))  #금액 =   10000
print("금액 =", format(10000, "6d"))  #금액 =  10000
print("금액 =", format(10000, "5d"))  #금액 = 10000

print("금액 =", format(125000, "3,d")) #금액 = 125,000

	# 형식 지정
	# print("형식문자" %(값1, 값2, ...))
		## %d 10진수 정수
		## %o 8진수 정수
		## %x 16진수 정의
		## %f 실수(%f전체자릿수.소수점자릿)
		## %s 문자열
		## %c 단일 문자열
print("금액 = %d" %(1024))
print("금액 = %6d + %6d" %(1024, 2048))
print("금액 = %08o(8)+ %08o(8)" %(1024, 2048))
print("금액 = %08x(16)+ %08x(16)" %(1024, 2048))
print("%3s = %8.3f" %("PI", 3.141592)) # 반올림 처리됨
print("%3c = %8.3f" %("P", 3.141592)) # 반올림 처리됨

	## 외부 상수 받기
	## "{}, {}". format(value1, value2)
print("name : {}, age : {}".format("홍길동","35")) # name : 홍길동, age : 35
print("name : {1}, age : {0}".format("홍길동","35")) # name : 35, age : 홍길동

	## format 축약형
	## select * from emp where name = '홍길동'
name, age = '홍길동', 35
sql = f"select * from emp where name = '{name}' and age = {age}"
print(sql)

