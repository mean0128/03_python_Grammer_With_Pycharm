# 1. 변수에 값 할당
i = tot = 10
i += 1
tot += i
print(i, tot)

	## swap
v1, v2, v3 = 100, 200, 300
print(v1, v2, v3)
v1,v2, v3 = v3,v2,v1
print(v1, v2, v3)

	## 패킹(packing) 할당
_1st = [1,2,3,4,5]
type(_1st)
*v1, v2, v3 = _1st
print(v1, v2, v3)


# 2. 연산자
	## 산술
num1 = -10
num2 = 2

add = num1+num2
subtract = num1 - num2
multiply = num1 * num2
divide = num1 / num2
divide2 = num1 // num2
mod = num1 % num2
square = num2 ** num2 ** num2
print(add, subtract, multiply, divide, divide2, mod, square)


