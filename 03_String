# 3. 문자열 처리 함수
lineStr = "   This is One Line String   "
len(lineStr)
lineStr.startswith('T')    # 해당 문자로 시작하는지 확인
lineStr.lower()            # 문자열 ⇒ 소문자
lineStr.upper()            # 문자열 ⇒ 대문자
lineStr.swapcase()         # 대문자 ⇔ 소문자
lineStr.lstrip()           # 좌 공백문자 제거
lineStr.rstrip()           # 우 공백문자 제거
lineStr.strip()            # 좌우 공백문자 제거
lineStr.count('is')        # 문자 빈도수 조회
lineStr.find('is')         # 왼쪽기준 문자 처음 등장하는 위치 조회
lineStr.rfind('is')        # 오른쪽기준 문자 처음 등장하는 위치 조회
lineStr.replace('i', 'a')  # 문자 변경

word = lineStr.split()  # 토큰 생성(문자열 분리), 인자 기준으로 문자 split, 디폴트는 공백문자
